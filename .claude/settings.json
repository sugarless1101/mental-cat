{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.staging)",
      "Read(.env.testing)",
      "Read(.env.backup)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Edit(.env.staging)",
      "Edit(.env.testing)",
      "Write(.env)",
      "Write(.env.production)",
      "Write(.env.staging)",
      "Read(storage/*.key)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.pfx)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Edit(*.pfx)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(*.pfx)",
      "Bash(rm -rf:*)",
      "Bash(php artisan db:wipe:*)",
      "Bash(php artisan migrate:fresh:*)",
      "Bash(format:*)",
      "Bash(diskpart:*)",
      "Bash(reg delete:*)",
      "Bash(bcdedit:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(php artisan migrate --force:*)",
      "Bash(composer remove:*)",
      "Bash(npm uninstall:*)"
    ],
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(php artisan:*)",
      "Bash(composer install:*)",
      "Bash(composer require:*)",
      "Bash(composer dump-autoload:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(./vendor/bin/pint:*)",
      "Bash(./vendor/bin/pest:*)"
    ]
  }
}
